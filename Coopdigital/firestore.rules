rules_version = '2';

// =====================================================================
// Reglas basadas en Custom Claims (request.auth.token.*), asignados por
// el Cloud Function syncUserClaims (ver functions/index.js) cada vez que
// se escribe cooperativas/{coopId}/usuarios/{uid}.
//
// Esto es lo que garantiza el aislamiento multi-tenant real: un usuario
// solo puede operar dentro de la cooperativa que figura en su propio
// token, sin lecturas extra a Firestore por cada chequeo de permiso.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function claims() {
      return request.auth.token;
    }

    function isActive() {
      return isAuthenticated() && claims().active == true;
    }

    function sameCooperativa(cooperativaId) {
      return claims().cooperativaId == cooperativaId;
    }

    function role() {
      return claims().role;
    }

    function isAdmin(cooperativaId) {
      return isActive() && sameCooperativa(cooperativaId) && role() == 'admin';
    }

    function puedeEscribirGeneral(cooperativaId) {
      return isActive() && sameCooperativa(cooperativaId) && role() in ['admin', 'consejero', 'operador'];
    }

    function puedeLeer(cooperativaId) {
      return isActive() && sameCooperativa(cooperativaId);
    }

    function puedeLeerUsuarios(cooperativaId) {
      return isActive() && sameCooperativa(cooperativaId) && role() in ['admin', 'consejero', 'sindico'];
    }

    match /cooperativas/{cooperativaId} {
      allow read: if puedeLeer(cooperativaId);
      allow write: if isAdmin(cooperativaId);

      // Usuarios: cada quien puede leer su propio documento (necesario para
      // resolver el perfil en el primer login, antes de tener claims).
      // Lectura completa: admin/consejero/sindico. Escritura: solo admin.
      match /usuarios/{usuarioId} {
        allow get: if isAuthenticated() && request.auth.uid == usuarioId;
        allow read: if puedeLeerUsuarios(cooperativaId);
        allow write: if isAdmin(cooperativaId);
      }

      match /asociados/{asociadoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /documentos/{documentoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /vencimientos/{vencimientoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
      }

      // Contabilidad: movimientos (ingresos/egresos) bajo categorías INAES
      // predefinidas en el frontend (registro simplificado, no partida
      // doble). Lectura: todos los roles activos. Escritura: admin/
      // consejero/operador. Baja: solo admin (trazabilidad contable).
      match /movimientosContables/{movimientoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      // Eventos: solo lectura desde frontend (admin/consejero/sindico).
      // Nunca se crean ni modifican desde el cliente.
      match /eventos/{eventoId} {
        allow read: if puedeLeerUsuarios(cooperativaId);
        allow write: if false;
      }
    }

    // Todo lo no contemplado explícitamente queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
