rules_version = '2';

// =====================================================================
// NOTA DE GOBERNANZA (ver SYSTEM_ARCHITECTURE.md / FIRESTORE_SECURITY_RULES.md)
//
// FIRESTORE_SECURITY_RULES.md define las funciones base (isActive, isAdmin,
// sameCooperativa, etc.) sobre Custom Claims (request.auth.token.*). Esos
// claims sólo pueden asignarse desde un Cloud Function (Admin SDK), que
// todavía no está implementado en este proyecto.
//
// Mientras tanto, estas reglas resuelven rol/activo/cooperativa leyendo
// directamente el documento de perfil del usuario con get(), en vez de
// leer el token. El efecto de seguridad es equivalente, pero:
//   - cada chequeo de rol cuenta como una lectura extra de Firestore.
//   - esto debe reemplazarse por la versión basada en Custom Claims en
//     cuanto exista el Cloud Function correspondiente (ver roadmap,
//     ítem "Crítico: Custom Claims").
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function perfil(cooperativaId) {
      return get(/databases/$(database)/documents/cooperativas/$(cooperativaId)/usuarios/$(request.auth.uid)).data;
    }

    function isActive(cooperativaId) {
      return isAuthenticated() && perfil(cooperativaId).activo == true;
    }

    function role(cooperativaId) {
      return perfil(cooperativaId).rol;
    }

    function isAdmin(cooperativaId) {
      return role(cooperativaId) == 'admin';
    }

    function puedeEscribirGeneral(cooperativaId) {
      return role(cooperativaId) in ['admin', 'consejero', 'operador'];
    }

    function puedeLeerUsuarios(cooperativaId) {
      return role(cooperativaId) in ['admin', 'consejero', 'sindico'];
    }

    match /cooperativas/{cooperativaId} {
      allow read: if isAuthenticated() && isActive(cooperativaId);
      allow write: if isAuthenticated() && isActive(cooperativaId) && isAdmin(cooperativaId);

      // Usuarios: lectura admin/consejero/sindico, escritura solo admin.
      // Excepción: cada usuario puede leer su propio documento (necesario
      // para resolver el perfil al iniciar sesión).
      match /usuarios/{usuarioId} {
        allow get: if isAuthenticated() && request.auth.uid == usuarioId;
        allow read: if isAuthenticated() && isActive(cooperativaId) && puedeLeerUsuarios(cooperativaId);
        allow write: if isAuthenticated() && isActive(cooperativaId) && isAdmin(cooperativaId);
      }

      // Asociados: lectura todos los roles activos, escritura admin/consejero/operador, baja solo admin.
      match /asociados/{asociadoId} {
        allow read: if isAuthenticated() && isActive(cooperativaId);
        allow create, update: if isAuthenticated() && isActive(cooperativaId) && puedeEscribirGeneral(cooperativaId);
        allow delete: if isAuthenticated() && isActive(cooperativaId) && isAdmin(cooperativaId);
      }

      // Documentos: lectura todos, carga admin/consejero/operador, baja solo admin.
      match /documentos/{documentoId} {
        allow read: if isAuthenticated() && isActive(cooperativaId);
        allow create, update: if isAuthenticated() && isActive(cooperativaId) && puedeEscribirGeneral(cooperativaId);
        allow delete: if isAuthenticated() && isActive(cooperativaId) && isAdmin(cooperativaId);
      }

      // Vencimientos: lectura todos, alta/modificación admin/consejero/operador.
      match /vencimientos/{vencimientoId} {
        allow read: if isAuthenticated() && isActive(cooperativaId);
        allow create, update: if isAuthenticated() && isActive(cooperativaId) && puedeEscribirGeneral(cooperativaId);
      }

      // Eventos: solo lectura desde frontend (admin/consejero/sindico). Nunca
      // se crean desde el cliente.
      match /eventos/{eventoId} {
        allow read: if isAuthenticated() && isActive(cooperativaId) && puedeLeerUsuarios(cooperativaId);
        allow write: if false;
      }
    }

    // Todo lo no contemplado explícitamente queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
