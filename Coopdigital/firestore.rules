rules_version = '2';

// =====================================================================
// MULTI-TENANT SIN CLOUD FUNCTIONS (plan Spark / gratuito).
//
// La asignación de cooperativaId por usuario se resuelve enteramente con
// reglas + dos lecturas de Firestore (sin Custom Claims, que requieren
// un Cloud Function en plan Blaze pago).
//
// Flujo:
//  1. usuariosIndex/{uid} (colección global, un doc por usuario) guarda
//     únicamente { cooperativaId }. Solo el propio usuario puede leer su
//     entrada. Solo se escribe vía Admin SDK (script de alta), nunca
//     desde el cliente.
//  2. Con ese cooperativaId, el cliente lee
//     cooperativas/{cooperativaId}/usuarios/{uid} para conocer rol y
//     estado activo (perfil completo).
//  3. El resto de las reglas usa perfil(cooperativaId) con get() para
//     verificar rol/activo en cada operación, igual que antes.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function perfil(cooperativaId) {
      return get(/databases/$(database)/documents/cooperativas/$(cooperativaId)/usuarios/$(request.auth.uid)).data;
    }

    function isActive(cooperativaId) {
      return isAuthenticated() && perfil(cooperativaId).activo == true;
    }

    function role(cooperativaId) {
      return perfil(cooperativaId).rol;
    }

    function isAdmin(cooperativaId) {
      return isActive(cooperativaId) && role(cooperativaId) == 'admin';
    }

    function puedeEscribirGeneral(cooperativaId) {
      return isActive(cooperativaId) && role(cooperativaId) in ['admin', 'consejero', 'operador'];
    }

    // Gobernanza institucional (Consejo, Sindicatura, Asambleas, Actas): solo
    // admin/consejero pueden escribir, NUNCA operador. Son actos de gobierno
    // cooperativo, distintos de las "operaciones diarias" del rol operador.
    function puedeEscribirGobernanza(cooperativaId) {
      return isActive(cooperativaId) && role(cooperativaId) in ['admin', 'consejero'];
    }

    function puedeLeer(cooperativaId) {
      return isActive(cooperativaId);
    }

    function puedeLeerUsuarios(cooperativaId) {
      return isActive(cooperativaId) && role(cooperativaId) in ['admin', 'consejero', 'sindico'];
    }

    // Índice global: uid -> cooperativaId. Solo lectura del propio usuario,
    // jamás de otros. Solo se escribe vía Admin SDK (bypassa estas reglas).
    match /usuariosIndex/{uid} {
      allow get: if isAuthenticated() && request.auth.uid == uid;
      allow list, write: if false;
    }

    match /cooperativas/{cooperativaId} {
      allow read: if puedeLeer(cooperativaId);
      allow write: if isAdmin(cooperativaId);

      // Usuarios: cada quien puede leer su propio documento (necesario para
      // resolver el perfil en el primer login). Lectura completa:
      // admin/consejero/sindico. Escritura: solo admin.
      match /usuarios/{usuarioId} {
        allow get: if isAuthenticated() && request.auth.uid == usuarioId;
        allow read: if puedeLeerUsuarios(cooperativaId);
        allow write: if isAdmin(cooperativaId);
      }

      match /asociados/{asociadoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /documentos/{documentoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /vencimientos/{vencimientoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
      }

      // Contabilidad: movimientos (ingresos/egresos) bajo categorías INAES
      // predefinidas en el frontend (registro simplificado, no partida
      // doble). Lectura: todos los roles activos. Escritura: admin/
      // consejero/operador. Baja: solo admin (trazabilidad contable).
      match /movimientosContables/{movimientoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      // Eventos: solo lectura desde frontend (admin/consejero/sindico).
      // Nunca se crean ni modifican desde el cliente.
      match /eventos/{eventoId} {
        allow read: if puedeLeerUsuarios(cooperativaId);
        allow write: if false;
      }

      // Gobernanza institucional: Consejo de Administración, Sindicatura,
      // Asambleas y Actas. Lectura para todos los roles activos, escritura
      // solo admin/consejero, baja solo admin.
      match /consejoAdministracion/{cargoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGobernanza(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /sindicatura/{sindicoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGobernanza(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /asambleas/{asambleaId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGobernanza(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      match /actas/{actaId} {
        allow read: if puedeLeer(cooperativaId);
        allow create, update: if puedeEscribirGobernanza(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
      }

      // Certificados: solo se crean, nunca se modifican (trazabilidad).
      match /certificados/{certificadoId} {
        allow read: if puedeLeer(cooperativaId);
        allow create: if puedeEscribirGeneral(cooperativaId);
        allow delete: if isAdmin(cooperativaId);
        allow update: if false;
      }
    }

    // Todo lo no contemplado explícitamente queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
